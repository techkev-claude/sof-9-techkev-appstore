# Admin-Zugangsdaten fuer das Web-Interface (Login-Seite)
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# API-Key, den die Android-App bei jedem Request an /api/v1/* im Header
# "X-API-Key" mitschicken muss.
API_KEY=changeme-api-key

# Secret zum Signieren der Session-Cookies des Web-Interfaces.
# WICHTIG: In Produktion zwingend auf einen zufaelligen, geheimen Wert setzen!
SECRET_KEY=changeme-secret

# Pfad zur SQLite-Datenbankdatei innerhalb des Containers
DB_PATH=/app/data/db.sqlite3

# Externer Port, unter dem der Appstore via Nginx erreichbar ist
PORT=8084

# Host-Pfad fuer persistente Daten (APKs, Icons, Datenbank)
DATA_PATH=/home/user/techkev-appstore/data

# Maximale APK-Dateigroesse in MB
APK_MAX_SIZE_MB=500
